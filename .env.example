# Airflow container user. On Linux use: echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000

GDELT_BACKFILL_MODE=local

# Google Trends is always rebuilt from a stable history start because values are
# relative, not absolute, and are normalized within request ranges, making
# incremental updates unreliable.
GOOGLE_TRENDS_START_DATE=2022-01-01

# Number of concurrent GDELT download workers.
GDELT_INGESTION_THREADS=3

# For local mode you can specify Spark configuration. 
# GDELT_SPARK_MASTER=local[3]
# GDELT_SPARK_CONF=spark.driver.memory=4g,spark.ui.showConsoleProgress=false
GDELT_SPARK_CONF=spark.ui.showConsoleProgress=false

# GCP specific settings below.
# Leave it as is if you don't plan to use gcp backfill mode.

# Required only for GCP mode. Rename the service-account key to this filename
# and place it in the project root.
GOOGLE_APPLICATION_CREDENTIALS=./gcp_creds.json

# GCS settings:
GCP_PROJECT_ID=your-gcp-project
GDELT_GCP_BUCKET=your-gcs-bucket
GDELT_GCP_STG_BUCKET=your-gcs-dataproc-meta-bucket

# Dataproc settings:
GDELT_DATAPROC_REGION=europe-west1
GDELT_DATAPROC_RUNTIME_VERSION=2.2
GDELT_DATAPROC_SERVICE_ACCOUNT=service-account@your-gcp-project.iam.gserviceaccount.com
GDELT_DATAPROC_SPARK_CONF=spark.dynamicAllocation.enabled=true,spark.dynamicAllocation.initialExecutors=5,spark.dynamicAllocation.minExecutors=5,spark.dynamicAllocation.maxExecutors=5,spark.driver.cores=4,spark.executor.cores=4
